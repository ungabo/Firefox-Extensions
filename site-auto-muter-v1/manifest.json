{
  "manifest_version": 3,
  "name": "Site Auto Muter",
  "version": "1.0",
  "description": "Automatically mutes tabs for sites on a saved list.",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "Site Auto Muter",
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "site-auto-muter@example.local"
    }
  }
}
